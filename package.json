{
  "name": "s-copy",
  "displayName": "S Copy",
  "description": "快速收集代码位置，批量反馈给 AI CLI 进行精准修复",
  "version": "0.1.0",
  "publisher": "s-copy",
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:sCopySidebar",
    "onView:sCopyHistory"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "s-copy",
          "title": "S Copy",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "s-copy": [
        {
          "type": "webview",
          "id": "sCopySidebar",
          "name": "代码收集"
        },
        {
          "type": "webview",
          "id": "sCopyHistory",
          "name": "历史记录"
        }
      ]
    },
    "commands": [
      {
        "command": "s-copy.collect",
        "title": "+ 收集",
        "category": "S Copy"
      },
      {
        "command": "s-copy.collectFromExplorer",
        "title": "+ 收集",
        "category": "S Copy"
      },
      {
        "command": "s-copy.openPanel",
        "title": "打开收集面板",
        "category": "S Copy"
      },
      {
        "command": "s-copy.clearStash",
        "title": "清空暂存",
        "category": "S Copy"
      }
    ],
    "keybindings": [
      {
        "command": "s-copy.collect",
        "key": "cmd+;",
        "mac": "cmd+;",
        "when": "editorTextFocus"
      },
      {
        "command": "s-copy.collect",
        "key": "ctrl+;",
        "win": "ctrl+;",
        "linux": "ctrl+;",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "s-copy.collect",
          "when": "editorHasSelection",
          "group": "9_cutcopypaste@100"
        }
      ],
      "explorer/context": [
        {
          "command": "s-copy.collectFromExplorer",
          "group": "5_cutcopypaste@100"
        }
      ]
    },
    "configuration": {
      "title": "S Copy",
      "properties": {
        "s-copy.historyLimit": {
          "type": "number",
          "default": 50,
          "description": "历史记录最大条数"
        },
        "s-copy.colors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["#4A90E2", "#F5A623", "#7ED321", "#BD10E0", "#8B572A"],
          "description": "代码块色块颜色列表"
        },
        "s-copy.promptPlaceholder": {
          "type": "string",
          "default": "例如：修复类型错误，检查边界情况...",
          "description": "AI 提示输入框占位文本"
        },
        "s-copy.showWelcome": {
          "type": "boolean",
          "default": true,
          "description": "首次使用时显示欢迎引导"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "ts-loader": "^9.5.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  }
}
